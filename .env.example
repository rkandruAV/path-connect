# ===========================================
# PathConnect — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -------------------------------------------
# Firebase (Frontend + Backend)
# -------------------------------------------
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Firebase Admin SDK (Backend only)
FIREBASE_SERVICE_ACCOUNT_KEY=./firebase-service-account.json

# -------------------------------------------
# API Server
# -------------------------------------------
API_PORT=4000
NODE_ENV=development
VITE_API_URL=/api/v1

# -------------------------------------------
# PostgreSQL
# -------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pathconnect
POSTGRES_USER=pathconnect
POSTGRES_PASSWORD=pathconnect_dev_password
DATABASE_URL=postgresql://pathconnect:pathconnect_dev_password@localhost:5432/pathconnect?schema=public

# -------------------------------------------
# Redis
# -------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# Dify
# -------------------------------------------
DIFY_BASE_URL=http://localhost:3080/v1
DIFY_API_KEY=your-dify-api-key

# -------------------------------------------
# n8n
# -------------------------------------------
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_WEBHOOK_URL=http://localhost:5678

# -------------------------------------------
# JWT / Session (if needed beyond Firebase)
# -------------------------------------------
JWT_SECRET=your-jwt-secret-change-in-production
