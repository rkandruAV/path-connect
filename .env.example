# ===========================================
# PathConnect — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -------------------------------------------
# Firebase (Frontend + Backend)
# -------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# Firebase Admin SDK (Backend only)
FIREBASE_SERVICE_ACCOUNT_KEY=./firebase-service-account.json

# -------------------------------------------
# API Server
# -------------------------------------------
API_PORT=4000
NODE_ENV=development
NEXT_PUBLIC_API_URL=/api/v1
API_INTERNAL_URL=http://localhost:4000

# -------------------------------------------
# PostgreSQL
# -------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pathconnect
POSTGRES_USER=pathconnect
POSTGRES_PASSWORD=pathconnect_dev_password
DATABASE_URL=postgresql://pathconnect:pathconnect_dev_password@localhost:5432/pathconnect?schema=public

# -------------------------------------------
# Redis
# -------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# Dify Cloud (cloud.dify.ai)
# -------------------------------------------
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_MENTOR_MATCHER_KEY=app-xxxxxxxxxxxxx
DIFY_SESSION_SUMMARIZER_KEY=app-xxxxxxxxxxxxx
DIFY_LEARNING_PATH_KEY=app-xxxxxxxxxxxxx
DIFY_AI_ADVISOR_KEY=app-xxxxxxxxxxxxx

# -------------------------------------------
# n8n
# -------------------------------------------
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_WEBHOOK_URL=http://localhost:5678

# -------------------------------------------
# JWT / Session (if needed beyond Firebase)
# -------------------------------------------
JWT_SECRET=your-jwt-secret-change-in-production
